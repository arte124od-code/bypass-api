<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bypass Shortlinks | The #1 Ad Links Bypasser</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root { --primary: #6366f1; --secondary: #8b5cf6; --bg: #0f172a; --bg-light: #1e293b; --text: #f8fafc; --text-muted: #94a3b8; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }
        
        nav { background: rgba(15,23,42,0.9); backdrop-filter: blur(10px); border-bottom: 1px solid #334155; position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1rem 0; }
        .nav-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 1.5rem; font-weight: 800; background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: flex; align-items: center; gap: 0.5rem; }
        .nav-links { display: flex; gap: 2rem; align-items: center; }
        .nav-links a { color: var(--text-muted); text-decoration: none; font-weight: 500; }
        .nav-links a:hover { color: var(--text); }
        .nav-btn { background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; padding: 0.6rem 1.2rem; border-radius: 8px; text-decoration: none; font-weight: 600; }
        
        .hero { padding: 10rem 2rem 6rem; text-align: center; background: radial-gradient(ellipse at top, rgba(99,102,241,0.15), transparent 50%); }
        .hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.3); padding: 0.5rem 1rem; border-radius: 50px; font-size: 0.875rem; color: #818cf8; margin-bottom: 2rem; }
        .hero h1 { font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 800; margin-bottom: 1rem; background: linear-gradient(to right, #fff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero p { color: var(--text-muted); font-size: 1.2rem; max-width: 600px; margin: 0 auto 3rem; }
        
        .input-container { max-width: 700px; margin: 0 auto 4rem; }
        .input-wrapper { display: flex; background: var(--bg-light); border: 2px solid #334155; border-radius: 16px; padding: 0.5rem; box-shadow: 0 20px 50px -10px rgba(0,0,0,0.5); }
        .url-input { flex: 1; background: transparent; border: none; padding: 1rem 1.5rem; color: var(--text); font-size: 1rem; outline: none; }
        .bypass-btn { background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; border: none; padding: 1rem 2rem; border-radius: 12px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; }
        .bypass-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 30px -5px rgba(99,102,241,0.5); }
        .bypass-btn:disabled { opacity: 0.7; }
        .bypass-btn.loading::after { content: ''; width: 20px; height: 20px; border: 2px solid transparent; border-top-color: white; border-radius: 50%; animation: spin 0.8s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .result-box { margin-top: 2rem; padding: 1.5rem; border-radius: 12px; display: none; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); }
        .result-box.show { display: block; animation: fadeIn 0.3s ease; }
        .result-box.error { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.3); }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        
        .stats { padding: 4rem 2rem; background: var(--bg-light); border-top: 1px solid #334155; border-bottom: 1px solid #334155; }
        .stats-grid { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 3rem; text-align: center; }
        .stat-number { font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .stat-label { color: var(--text-muted); }
        
        .features { padding: 6rem 2rem; max-width: 1200px; margin: 0 auto; }
        .section-header { text-align: center; margin-bottom: 4rem; }
        .section-header h2 { font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; }
        .section-header p { color: var(--text-muted); }
        .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
        .feature-card { background: var(--bg-light); border: 1px solid #334155; border-radius: 16px; padding: 2rem; transition: transform 0.3s; }
        .feature-card:hover { transform: translateY(-5px); border-color: var(--primary); }
        .feature-icon { font-size: 2.5rem; margin-bottom: 1rem; }
        
        .supported { padding: 6rem 2rem; background: var(--bg-light); }
        .supported-grid { max-width: 1000px; margin: 2rem auto 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; }
        .site-card { background: var(--bg); border: 1px solid #334155; border-radius: 12px; padding: 1.25rem; display: flex; align-items: center; gap: 1rem; }
        .site-icon { font-size: 1.5rem; width: 48px; height: 48px; background: rgba(99,102,241,0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; }
        
        .discord-section { padding: 6rem 2rem; background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1)); text-align: center; }
        .discord-container { max-width: 600px; margin: 0 auto; }
        .discord-logo { font-size: 4rem; margin-bottom: 1rem; }
        .discord-section h2 { font-size: 2.5rem; margin-bottom: 1rem; }
        .discord-card { background: var(--bg-light); border: 1px solid #334155; border-radius: 20px; padding: 2rem; margin-top: 2rem; }
        .discord-profile { display: flex; align-items: center; gap: 1rem; background: rgba(88,101,242,0.1); padding: 1rem 1.5rem; border-radius: 50px; margin-bottom: 1.5rem; justify-content: center; }
        .discord-avatar { width: 48px; height: 48px; background: #5865F2; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
        .discord-btn { display: inline-flex; align-items: center; gap: 0.75rem; background: #5865F2; color: white; padding: 1rem 2rem; border-radius: 12px; text-decoration: none; font-weight: 600; font-size: 1.1rem; }
        
        footer { padding: 3rem 2rem; text-align: center; color: var(--text-muted); border-top: 1px solid #334155; }
        
        @media (max-width: 768px) {
            .nav-links { display: none; }
            .input-wrapper { flex-direction: column; }
            .bypass-btn { width: 100%; justify-content: center; }
            .stats-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <nav>
        <div class="nav-container">
            <div class="logo"><span>⚡</span> Bypass</div>
            <div class="nav-links">
                <a href="#features">Features</a>
                <a href="#supported">Supported</a>
                <a href="#discord">Discord</a>
                <a href="<%= discord %>" target="_blank" class="nav-btn">Join Discord</a>
            </div>
        </div>
    </nav>
    
    <section class="hero">
        <div class="hero-badge"><span>🚀</span> The #1 Ad Links Bypasser</div>
        <h1>Bypass Shortlinks Instantly</h1>
        <p>Bypass links instantly with our advanced system! Support for Linkvertise, LootLabs, Work.ink, and more.</p>
        
        <div class="input-container">
            <div class="input-wrapper">
                <input type="text" id="urlInput" class="url-input" placeholder="Paste your link here...">
                <button class="bypass-btn" id="bypassBtn" onclick="bypass()"><span>🔓</span> Bypass</button>
            </div>
            <div id="resultBox" class="result-box">
                <h3 style="color: #22c55e; margin-bottom: 1rem;">✅ Success!</h3>
                <a href="#" id="resultLink" target="_blank" style="color: #818cf8; word-break: break-all;"></a>
            </div>
        </div>
    </section>
    
    <section class="stats">
        <div class="stats-grid">
            <div><div class="stat-number">50M+</div><div class="stat-label">Links Bypassed</div></div>
            <div><div class="stat-number">35+</div><div class="stat-label">Supported Services</div></div>
            <div><div class="stat-number">5+</div><div class="stat-label">Years of Service</div></div>
            <div><div class="stat-number">100%</div><div class="stat-label">Free</div></div>
        </div>
    </section>
    
    <section class="features" id="features">
        <div class="section-header">
            <h2>Why Choose Us?</h2>
            <p>We provide the best bypass service with cutting-edge technology.</p>
        </div>
        <div class="features-grid">
            <div class="feature-card"><div class="feature-icon">⚡</div><h3>Fast & Reliable</h3><p>Bypass links in seconds with our advanced system.</p></div>
            <div class="feature-card"><div class="feature-icon">💯</div><h3>100% Free</h3><p>Completely free to use, no hidden fees or subscriptions.</p></div>
            <div class="feature-card"><div class="feature-icon">🌐</div><h3>Multiple Websites</h3><p>Support for Linkvertise, LootLabs, Work.ink, and more.</p></div>
            <div class="feature-card"><div class="feature-icon">🔒</div><h3>Safe & Secure</h3><p>We don't store your links or personal data.</p></div>
            <div class="feature-card"><div class="feature-icon">📱</div><h3>Mobile Friendly</h3><p>Works perfectly on all devices.</p></div>
            <div class="feature-card"><div class="feature-icon">🤖</div><h3>API Available</h3><p>Integrate bypass functionality into your apps.</p></div>
        </div>
    </section>
    
    <section class="supported" id="supported">
        <div class="section-header"><h2>Supported Websites</h2><p>We support all major link shorteners.</p></div>
        <div class="supported-grid">
            <% supported.forEach(site => { %>
                <div class="site-card">
                    <div class="site-icon"><%= site.icon %></div>
                    <div><h4><%= site.name %></h4><p style="color: #94a3b8; font-size: 0.8rem;"><%= site.domains[0] %></p></div>
                </div>
            <% }) %>
        </div>
    </section>
    
    <section class="discord-section" id="discord">
        <div class="discord-container">
            <div class="discord-logo">💬</div>
            <h2>Join Our Community</h2>
            <p>Connect with us on Discord for support and updates!</p>
            <div class="discord-card">
                <div class="discord-profile">
                    <div class="discord-avatar">👤</div>
                    <div><div style="font-weight: 700;">Developer</div><div style="color: #94a3b8; font-size: 0.85rem;">ID: <%= userId %></div></div>
                </div>
                <a href="<%= discord %>" target="_blank" class="discord-btn">🚀 Join Discord Server</a>
            </div>
        </div>
    </section>
    
    <footer>
        <p>Made with ❤️ | <a href="<%= discord %>" style="color: #818cf8;">Join our Discord</a></p>
    </footer>
    
    <script>
        async function bypass() {
            const input = document.getElementById('urlInput');
            const btn = document.getElementById('bypassBtn');
            const resultBox = document.getElementById('resultBox');
            const resultLink = document.getElementById('resultLink');
            const url = input.value.trim();
            
            if (!url) return alert('Please enter a URL');
            
            btn.disabled = true;
            btn.classList.add('loading');
            btn.innerHTML = '';
            resultBox.classList.remove('show');
            
            try {
                const res = await fetch(`/api/bypass?url=${encodeURIComponent(url)}`);
                const data = await res.json();
                
                btn.disabled = false;
                btn.classList.remove('loading');
                btn.innerHTML = '<span>🔓</span> Bypass';
                
                if (data.success) {
                    resultBox.className = 'result-box show';
                    resultLink.href = data.result;
                    resultLink.textContent = data.result;
                } else {
                    resultBox.className = 'result-box show error';
                    resultLink.href = '#';
                    resultLink.textContent = data.error || 'Failed to bypass';
                }
            } catch (err) {
                btn.disabled = false;
                btn.classList.remove('loading');
                btn.innerHTML = '<span>🔓</span> Bypass';
                resultBox.className = 'result-box show error';
                resultLink.textContent = err.message;
            }
        }
        
        document.getElementById('urlInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') bypass();
        });
    </script>
</body>
</html>
