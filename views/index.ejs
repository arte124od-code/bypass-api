<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Script Facil</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        :root{--p:#6366f1;--b:#0f172a;--l:#1e293b;--t:#f8fafc;--m:#94a3b8}
        body{font-family:system-ui;background:var(--b);color:var(--t)}
        .menu{position:fixed;top:20px;right:20px;z-index:1001;cursor:pointer;padding:10px;background:rgba(255,255,255,0.1);border-radius:8px;border:none}
        .menu span{display:block;width:25px;height:3px;background:white;margin:5px 0}
        .side{position:fixed;top:0;right:-100%;width:300px;height:100vh;background:var(--l);border-left:1px solid #334155;transition:0.3s;z-index:1000;padding:80px 20px}
        .side.active{right:0}
        .over{position:fixed;inset:0;background:rgba(0,0,0,0.5);opacity:0;visibility:hidden;transition:0.3s;z-index:999}
        .over.active{opacity:1;visibility:visible}
        .nav{display:block;padding:15px;color:var(--t);text-decoration:none;border-radius:8px;margin:5px 0}
        .nav:hover{background:rgba(255,255,255,0.1)}
        .hero{padding:120px 20px 60px;text-align:center;background:radial-gradient(ellipse at top,rgba(99,102,241,0.2),transparent 50%)}
        .title{font-size:clamp(3rem,10vw,6rem);font-weight:900;background:linear-gradient(135deg,#fff,var(--p));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:20px}
        .sub{color:var(--m);font-size:1.2rem;margin-bottom:40px}
        .box{max-width:600px;margin:0 auto;display:flex;background:var(--l);border:1px solid #334155;border-radius:12px;padding:5px}
        .box input{flex:1;background:transparent;border:none;padding:15px;color:white;font-size:1rem;outline:none}
        .box button{background:var(--p);color:white;border:none;padding:15px 30px;border-radius:8px;font-weight:600;cursor:pointer}
        .res{margin-top:20px;padding:20px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);border-radius:8px;display:none;word-break:break-all}
        .res.show{display:block}
        .res a{color:#818cf8}
        .creator{padding:60px 20px;background:var(--l);text-align:center}
        .creator h2{font-size:2rem;margin-bottom:30px}
        .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;max-width:800px;margin:0 auto}
        .card{background:var(--b);border:1px solid #334155;border-radius:16px;padding:30px 20px;text-decoration:none;color:white;transition:0.3s}
        .card:hover{transform:translateY(-5px);border-color:var(--p)}
        .card img{width:80px;height:80px;border-radius:50%;margin-bottom:15px;object-fit:cover;border:3px solid var(--p);background:white}
        .name{font-weight:700;font-size:1.1rem;margin-bottom:5px}
        .info{color:var(--m);font-size:0.9rem;margin-bottom:10px}
        .tag{display:inline-block;background:rgba(99,102,241,0.2);padding:5px 15px;border-radius:20px;font-size:0.8rem}
        footer{padding:30px;text-align:center;color:var(--m);border-top:1px solid #334155}
        footer a{color:var(--p);text-decoration:none}
        @media(max-width:600px){.box{flex-direction:column}.grid{grid-template-columns:1fr}}
    </style>
</head>
<body>
    <button class="menu" onclick="toggle()"><span></span><span></span><span></span></button>
    <div class="over" onclick="toggle()"></div>
    <div class="side" id="side">
        <a href="#" class="nav" onclick="toggle()">🏠 Início</a>
        <a href="#creator" class="nav" onclick="toggle()">👤 Criador</a>
        <a href="<%= creator.discordInvite %>" class="nav" target="_blank">💬 Discord</a>
    </div>
    <div class="hero">
        <h1 class="title">SCRIPT FACIL</h1>
        <p class="sub">Bypass em links encurtados</p>
        <div class="box">
            <input type="text" id="url" placeholder="Cole seu link...">
            <button onclick="bypass()">Bypass</button>
        </div>
        <div id="res" class="res">
            <p>✅ Sucesso!</p>
            <a id="link" href="#" target="_blank"></a>
        </div>
    </div>
    <div class="creator" id="creator">
        <h2>👤 Sobre o Criador</h2>
        <div class="grid">
            <a href="https://discord.com/users/<%= creator.discordId %>" target="_blank" class="card">
                <img src="https://cdn.discordapp.com/embed/avatars/0.png">
                <div class="name">Discord</div>
                <div class="info">ID: <%= creator.discordId %></div>
                <span class="tag">💬 Ver Perfil</span>
            </a>
            <a href="<%= creator.instagramUrl %>" target="_blank" class="card">
                <img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Instagram_icon.png">
                <div class="name">Instagram</div>
                <div class="info">@<%= creator.instagram %></div>
                <span class="tag">📷 Seguir</span>
            </a>
            <a href="<%= creator.robloxUrl %>" target="_blank" class="card">
                <img src="https://upload.wikimedia.org/wikipedia/commons/c/c7/Roblox_logo.svg" style="padding:10px">
                <div class="name">Roblox</div>
                <div class="info"><%= creator.robloxUser %></div>
                <span class="tag">🎮 Ver Perfil</span>
            </a>
            <div class="card" style="cursor:default">
                <img src="https://upload.wikimedia.org/wikipedia/en/6/61/Free_Fire_Logo.png" style="padding:10px">
                <div class="name">Free Fire</div>
                <div class="info">ID: <%= creator.freefireId %></div>
                <span class="tag">🔥 Adicionar</span>
            </div>
        </div>
    </div>
    <footer>
        <p>🚀 Script Facil | <a href="<%= creator.discordInvite %>">Discord</a></p>
    </footer>
    <script>
        function toggle(){
            document.getElementById('side').classList.toggle('active');
            document.querySelector('.over').classList.toggle('active')
        }
        async function bypass(){
            const u=document.getElementById('url').value;
            if(!u)return alert('Digite URL!');
            try{
                const r=await fetch('/api/bypass?url='+encodeURIComponent(u));
                const d=await r.json();
                if(d.success){
                    document.getElementById('res').classList.add('show');
                    document.getElementById('link').href=d.result;
                    document.getElementById('link').textContent=d.result
                }else{
                    alert('Erro')
                }
            }catch(e){
                alert('Erro')
            }
        }
        document.getElementById('url').addEventListener('keypress',e=>{
            if(e.key==='Enter')bypass()
        })
    </script>
</body>
</html>
